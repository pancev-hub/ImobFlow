{
  "name": "imobflow",
  "version": "1.0.0",
  "description": "Sistema profissional para imobiliárias - ImobFlow",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "apps/backend",
    "apps/web",
    "packages/ui",
    "packages/types",
    "packages/utils"
  ],
  "scripts": {
    "dev": "yarn workspaces foreach -p run dev",
    "build": "yarn workspaces foreach -p run build",
    "lint": "yarn workspaces foreach -p run lint",
    "type-check": "yarn workspaces foreach -p run type-check",
    "test": "yarn workspaces foreach -p run test",
    "mobile:dev": "yarn workspace @imobflow/mobile dev",
    "mobile:build": "yarn workspace @imobflow/mobile build",
    "backend:dev": "yarn workspace @imobflow/backend dev",
    "backend:build": "yarn workspace @imobflow/backend build",
    "web:dev": "yarn workspace @imobflow/web dev",
    "web:build": "yarn workspace @imobflow/web build",
    "db:migrate": "yarn workspace @imobflow/backend db:migrate",
    "db:seed": "yarn workspace @imobflow/backend db:seed",
    "db:studio": "yarn workspace @imobflow/backend db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=3.0.0"
  }
}
